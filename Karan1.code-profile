tion, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t\\\"C boilerplate\\\": {\\n\\t\\t\\\"prefix\\\": \\\"c boiler\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#include <stdio.h>\\\\n\\\",\\n\\t\\t\\t\\\"int main(){\\\", \\n\\t\\t\\t\\\"\\\\t$1\\\", \\n\\t\\t\\t\\\"\\\\treturn 0;\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"The C language boilerplate\\\"\\n\\t},\\n\\n\\\"C print\\\": {\\n  \\\"prefix\\\": \\\"mprintf\\\",\\n  \\\"body\\\": [\\n    \\\"printf(\\\\\\\"$1\\\\\\\");\\\"\\n  ],\\n  \\\"description\\\": \\\"The C printf\\\"\\n},\\n\\n\\\"C scan\\\": {\\n  \\\"prefix\\\": \\\"mscanf\\\",\\n  \\\"body\\\": [\\n    \\\"scanf(\\\\\\\"%$1\\\\\\\", &$2);\\\"\\n  ],\\n  \\\"description\\\": \\\"The C scanf\\\"\\n}\\n\\n\\n}\",\"cpp.json\":\"{\\n\\t\\n\\t\\\"C++ boilerplate\\\": {\\n\\t\\t\\\"prefix\\\": \\\"cpp\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#include <iostream> // main Liabrary Function\\\",\\n\\t\\t\\t\\\" #include <cstdio> // useing this we do printf & scanf  \\\",\\n\\t\\t\\t\\\"#include <iomanip>    // use for text manuplating \\\",\\n\\t\\t\\t\\\"#include <cstring>   // use for   string\\\",\\n \\t\\t\\t\\\"#include <fstream> // for file handling\\\",\\n\\t\\t\\t\\\"#include <unistd.h> // for sleep\\\",\\n     \\t\\t\\\"using namespace std; // for string\\\",\\n\\n            \\\"\\\\t $1\\\",\\n\\n\\t\\t\\t\\\"int main()\\\",\\n\\t\\t\\t\\\"{\\\",\\n\\t\\t\\t\\\"\\\\t$2\\\",\\n\\t\\t\\t\\\"\\\\treturn 0;\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"The C language boilerplate\\\"\\n\\t},\\n\\t\\\"C++ print\\\": {\\n\\t\\t\\\"prefix\\\": \\\"mcout\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"cout << \\\\\\\"$1\\\\\\\" << $2  endl;\\\",\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"this is cout \\\",\\n},\\n\\n\\t\\n\\t\\\"C++ scan\\\": {\\n\\t\\t\\\"prefix\\\": \\\"mcin\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"cin>>$1;$2\\\",\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"this is cin\\\", \\n},\\n\\n\\n\\t\\\"C++ class\\\": {\\n\\t\\t\\\"prefix\\\": \\\"mclass\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"class $1{$2\\\",\\n\\t\\t\\t\\\"public:\\\",\\n\\t\\t\\t\\\"$3\\\",\\n\\n\\t\\t\\\"}; $4\\\"\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"this is class\\\", \\n},\\n\\n\\n\\\"C++ classsecound\\\": {\\n\\t\\t\\\"prefix\\\": \\\"sclass\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"class $1: public $2{$3\\\",\\n\\t\\t\\t\\\"public:\\\",\\n\\t\\t\\t\\\"$4\\\",\\n\\n\\t\\t\\\"}; $5\\\"\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"this is for derive class\\\", \\n\\t},\\n\\t\\\"C++ File Open in write mode\\\":{\\n\\t\\t\\n\\t\\t\\\"prefix\\\": \\\"wfile\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"ofstream File$1;//any name for set\\\",\\n\\t\\t\\t\\\"File$2.open($3);//replace File to your set name \\\",\\n\\t\\t\\t\\\"File.close();//replace the File to your set name \\\",\\n\\t\\n\\t\\t\\\"}; $4\\\"\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"this is file klhandling to open in write mode\\\", \\n},\\n\\t\\\"C++ File Open in Read mode\\\":{\\n\\t\\t\\n\\t\\t\\\"prefix\\\": \\\"rfile\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"ifstream File$1;//any name for set\\\",\\n\\t\\t\\t\\\"File$2.open($3);//replace File to your set name \\\",\\n\\t\\t\\t\\\"File.close();//replace the File to your set name \\\",\\n\\t\\n\\t\\t\\\"}; $4\\\"\\n\\t\\t\\t\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"this is file klhandling to open in write mode\\\", \\n}\\n\\n\\n}\",\"css.json\":\"{\\n\\t\\\"Responsive Nav CSS\\\": {\\n\\t\\t\\\"prefix\\\": \\\"navcss\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\":root {\\\",\\n\\t\\t\\t\\\"  --white: #e1e4e4;\\\",\\n\\t\\t\\t\\\"  --buttons: #1a5aed;\\\",\\n\\t\\t\\t\\\"  --body: #010e1d;\\\",\\n\\t\\t\\t\\\"  --nav: #020c1a;\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"* {\\\",\\n\\t\\t\\t